"""
Differentiable PDE Solver for Tumor-Immune-Viral Dynamics
Implements reaction-diffusion system with analytical gradients

Author: Padmasri Sridharan
"""

import torch
import torch.nn as nn
import torch.nn.functional as F
from typing import Tuple, Optional


class DifferentiablePDESolver(nn.Module):
    """
    Differentiable PDE Solver for the reaction-diffusion system.
    
    Solves:
    ∂u/∂t = D∇²u + R(u; p) + S(x,t)
    
    where u = [H, C, V, I] representing:
    - H: HPV viral load
    - C: Cytological abnormality score
    - V: Tumor cell density
    - I: Immune cell density
    
    Args:
        config (dict): Configuration dictionary with PDE solver parameters
    """
    
    def __init__(self, config: dict):
        super(DifferentiablePDESolver, self).__init__()
        
        self.grid_size = config.get('grid_size', 64)
        self.dx = config.get('spatial_resolution', 0.5)  # mm
        self.n_steps = config.get('n_steps', 24)  # months
        self.dt = config.get('dt', 0.5)  # days
        self.adaptive_timestep = config.get('adaptive_timestep', True)
        
        # Laplacian kernel (5-point stencil)
        self.register_buffer(
            'laplacian_kernel',
            torch.tensor([[[[0, 1, 0], [1, -4, 1], [0, 1, 0]]]], dtype=torch.float32) / (self.dx ** 2)
        )
    
    def forward(
        self,
        u0: torch.Tensor,
        pde_params: torch.Tensor,
        treatment_fields: Optional[torch.Tensor] = None,
        return_all_steps: bool = True
    ) -> torch.Tensor:
        """
        Solve PDE forward in time using 4th-order Runge-Kutta (RK4).
        
        Args:
            u0: Initial conditions [batch_size, 4, grid_size, grid_size]
            pde_params: PDE parameters [batch_size, 8]
            treatment_fields: Time-varying treatment fields [batch_size, 4, grid_size, grid_size, n_steps]
            return_all_steps: Return all time steps or only final state
        
        Returns:
            u_t: Solution at all time steps [batch_size, 4, grid_size, grid_size, n_steps]
                 or final state only [batch_size, 4, grid_size, grid_size]
        """
        batch_size = u0.shape[0]
        u = u0.clone()
        
        if treatment_fields is None:
            treatment_fields = torch.zeros(
                batch_size, 4, self.grid_size, self.grid_size, self.n_steps,
                device=u0.device
            )
        
        # Storage for all time steps
        if return_all_steps:
            u_all = torch.zeros(
                batch_size, 4, self.grid_size, self.grid_size, self.n_steps,
                device=u0.device
            )
        
        for t_idx in range(self.n_steps):
            # Get treatment at current time
            treatment = treatment_fields[..., t_idx]
            
            # RK4 integration
            k1 = self._compute_dudt(u, pde_params, treatment)
            k2 = self._compute_dudt(u + 0.5 * self.dt * k1, pde_params, treatment)
            k3 = self._compute_dudt(u + 0.5 * self.dt * k2, pde_params, treatment)
            k4 = self._compute_dudt(u + self.dt * k3, pde_params, treatment)
            
            u = u + (self.dt / 6.0) * (k1 + 2 * k2 + 2 * k3 + k4)
            
            if return_all_steps:
                u_all[..., t_idx] = u
        
        if return_all_steps:
            return u_all
        return u
    
    def _compute_dudt(
        self,
        u: torch.Tensor,
        pde_params: torch.Tensor,
        treatment: torch.Tensor
    ) -> torch.Tensor:
        """
        Compute ∂u/∂t = D∇²u + R(u; p) + S(x,t).
        
        Args:
            u: State variables [batch_size, 4, grid_size, grid_size]
            pde_params: PDE parameters [batch_size, 8]
            treatment: Treatment effects at current time [batch_size, 4, grid_size, grid_size]
        
        Returns:
            dudt: Time derivative [batch_size, 4, grid_size, grid_size]
        """
        batch_size = u.shape[0]
        dudt = torch.zeros_like(u)
        
        # Extract state variables
        H = u[:, 0:1, :, :]  # HPV viral load
        C = u[:, 1:2, :, :]  # Cytological abnormality
        V = u[:, 2:3, :, :]  # Tumor cell density
        I = u[:, 3:4, :, :]  # Immune cell density
        
        # Extract PDE parameters
        alpha = pde_params[:, 0:1].unsqueeze(-1).unsqueeze(-1)  # HPV clearance rate
        beta_H = pde_params[:, 1:2].unsqueeze(-1).unsqueeze(-1)  # HPV to cytological rate
        beta_I = pde_params[:, 2:3].unsqueeze(-1).unsqueeze(-1)  # Immune clearance of abnormal cells
        gamma = pde_params[:, 3:4].unsqueeze(-1).unsqueeze(-1)  # Immune-mediated killing
        kappa = pde_params[:, 4:5].unsqueeze(-1).unsqueeze(-1)  # Tumor proliferation
        delta_V = pde_params[:, 5:6].unsqueeze(-1).unsqueeze(-1)  # Natural tumor death
        lambda_param = pde_params[:, 6:7].unsqueeze(-1).unsqueeze(-1)  # Immune recruitment from C
        mu = pde_params[:, 7:8].unsqueeze(-1).unsqueeze(-1)  # Immune recruitment from V
        
        # Diffusion coefficients
        D_H = 0.01  # HPV diffusion
        D_C = 0.02  # Cytological abnormality diffusion
        D_V = 0.005  # Tumor diffusion
        D_I = 0.015  # Immune diffusion
        
        # Laplacian (diffusion)
        laplacian = F.conv2d(u.view(-1, 1, self.grid_size, self.grid_size), self.laplacian_kernel, padding=1)
        laplacian = laplacian.view(batch_size, 4, self.grid_size, self.grid_size)
        
        # HPV dynamics (Equation 2)
        H_max = 10000.0
        r_H = 0.2
        growth_H = r_H * H * (1 - H / H_max)
        immune_clearance_H = alpha * H * I
        decay_H = 0.05 * H
        dHdt = D_H * laplacian[:, 0:1, :, :] + growth_H - immune_clearance_H - decay_H + treatment[:, 0:1, :, :]
        
        # Cytological abnormality dynamics (Equation 3)
        progression = beta_H * H * (1 - C)
        immune_clearance_C = beta_I * I * C
        reversion = 0.02 * C
        dCdt = D_C * laplacian[:, 1:2, :, :] + progression - immune_clearance_C - reversion + treatment[:, 1:2, :, :]
        
        # Tumor cell density dynamics (Equation 4)
        V_max = 1.0
        growth_V = kappa * V * (1 - V / V_max)
        immune_killing = gamma * I * V
        death_V = delta_V * V
        dVdt = D_V * laplacian[:, 2:3, :, :] + growth_V - immune_killing - death_V + treatment[:, 2:3, :, :]
        
        # Immune cell density dynamics (Equation 5)
        recruitment_C = lambda_param * C
        recruitment_V = mu * V
        turnover_I = 0.05 * I
        dIdt = D_I * laplacian[:, 3:4, :, :] + recruitment_C + recruitment_V - turnover_I + treatment[:, 3:4, :, :]
        
        # Assemble
        dudt = torch.cat([dHdt, dCdt, dVdt, dIdt], dim=1)
        
        # Apply non-negativity constraint
        dudt = torch.clamp(dudt, min=-1e6)
        
        return dudt
